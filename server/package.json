{
  "name": "server",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun --hot index.ts",
    "build": "bun build index.ts --outdir ./dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts seed",
    "db:reset": "bun src/db/seed.ts reset",
    "db:delete": "bun src/db/seed.ts delete",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@faker-js/faker": "^10.3.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
